{
  "services": [
      {
          "name": "http_service",
          "target_ip": "http_service",
          "target_port": 80,
          "listen_port": 80,
          "http": true
      },
      {
          "name": "https_service",
          "target_ip": "https_service",
          "target_port": 443,
          "listen_port": 443,
          "http": false
      }
  ],
  
  "global_config": {
      "keyword": "EH! VOLEVI",
      "verbose": false,
      "nginx": {
        "connect_timeout": 5,
        "max_fails": 1,
        "fail_timeout": 20
      },
      "dos": {
          "enabled": false,
          "duration": 60,
          "interval": 2
      },
      "max_stored_messages": 10,
      "max_message_size": 65535,
      "checker_rtt_threshold_us": null
  }
}